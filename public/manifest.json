{
  "manifest_version": 3,
  "name": "Timezone Clock",
  "version": "1.0.0",
  "description": "A real-time multi-timezone world clock for your new tab",
  "permissions": ["storage"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "host_permissions": ["https://timezone-clock-backend-server.vercel.app/*"]
}
